# IBKR Connection Settings
# Host where IB Gateway/TWS is running
IB_HOST=127.0.0.1

# Port for IB Gateway (paper: 4002, live: 4001) or TWS (paper: 7497, live: 7496)
IB_PORT=4002

# Unique client ID for this connection (1-32)
IB_CLIENT_ID=1

# Primary Account Configuration
# The "manager/master" account that will be monitored
PRIMARY_ACCOUNT=U1234567

# Follower Account Configuration
# Option 1: Simple list of accounts (equal quantity copying)
# FOLLOWER_ACCOUNTS=["U7654321","U1111111"]

# Option 2: Advanced rules with multipliers (recommended)
# JSON format: {"account_id": {"multiplier": 1.0, "enabled": true}}
COPY_RULES={"U7654321":{"multiplier":1.0,"enabled":true},"U1111111":{"multiplier":0.5,"enabled":true}}

# Safety Settings
# Set to "true" to log orders without placing them (for testing)
DRY_RUN=false

# Comma-separated list of symbols to copy (empty = copy all)
# Example: COPY_SYMBOLS=AAPL,MSFT,GOOGL
COPY_SYMBOLS=

# Position Sizing Mode
# true = Use same % of buying power as master (proportional to account size)
# false = Use multipliers configured in COPY_RULES
# Example: Master uses 10% of buying power → Followers use 10% of THEIR buying power
USE_PROPORTIONAL_SIZING=false

# Reconnection Settings
# Maximum number of reconnection attempts
RECONNECT_MAX_ATTEMPTS=10

# Initial delay between reconnection attempts (seconds)
RECONNECT_INITIAL_DELAY=1.0

# Maximum delay between reconnection attempts (seconds)
RECONNECT_MAX_DELAY=300.0

# Backoff multiplier for exponential backoff
RECONNECT_BACKOFF_FACTOR=2.0

# State Persistence
# Path to SQLite database for storing order mappings
STATE_DB_PATH=/data/copier_state.db

# Health Check
# Enable HTTP health check endpoint
HEALTH_CHECK_ENABLED=true

# Port for health check endpoint
HEALTH_CHECK_PORT=8080

# Logging Configuration
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json or text
LOG_FORMAT=json

# Rate Limiting
# Maximum orders per minute to prevent pacing violations
ORDER_RATE_LIMIT=50

# Copier Identification
# Tag added to follower orders to prevent loops
COPIER_TAG=COPIER_AUTO
